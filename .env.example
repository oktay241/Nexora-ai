# Supabase (https://supabase.com/dashboard/project/_/settings/api)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# OpenAI — yalnızca sunucu tarafında kullanılır (Server Actions). İstemciye koymayın.
OPENAI_API_KEY=

# İsteğe bağlı: varsayılan gpt-4o-mini
# OPENAI_MODEL=gpt-4o-mini

# Images API — varsayılan gpt-image-1 (dall-e-3 kullanılmaz). İsteğe bağlı: dall-e-2
# OPENAI_IMAGE_MODEL=gpt-image-1
# OPENAI_IMAGE_QUALITY=high

# Meta OAuth — Instagram bağlantısı (Facebook Login)
META_APP_ID=
META_APP_SECRET=
# Callback tam URL; Meta uygulama ayarı ile birebir aynı olmalı
# NEXORA_PUBLISH_OAUTH_REDIRECT_URI=https://yourdomain.com/api/social/connect/callback
# NEXORA_DEBUG_OAUTH=1

# Buffer GraphQL (https://publish.buffer.com/settings/api) — isteğe bağlı yayın köprüsü
BUFFER_ACCESS_TOKEN=
